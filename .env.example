PORT=4000
JWT_SECRET=change-me-in-local-env
AGENT_TOKEN=change-me-agent-token

# --- Database ---
# Default: local embedded PGlite, file-backed at the path below (dev). Tests always use
# in-memory PGlite regardless of this setting (NODE_ENV=test).
DATABASE_URL=file://./.data/ck.db

# To use SUPABASE instead (D8 — Supabase Cloud as the production DB), replace the line
# above with your project's TRANSACTION POOLER connection string (port 6543) from
# Supabase > Project Settings > Database > Connection string > Transaction pooler —
# NOT the direct connection (port 5432) and NOT the session pooler. The app detects a
# postgres://|postgresql:// URL and switches to drizzle-orm/postgres-js automatically;
# PGlite is used otherwise.
#
# IMPORTANT pooler notes (already handled in src/db/client.ts, nothing to add to the URL):
#   - prepare: false  — REQUIRED. The transaction pooler does not support prepared
#                       statements; leaving this on causes "prepared statement already
#                       exists" / connection errors under the pooler.
#   - ssl: "require"  — Supabase requires TLS; the postgres-js client is created with
#                       this set, so you do not need `?sslmode=require` in the URL.
#
# DATABASE_URL=postgresql://postgres.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
