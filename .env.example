# ─────────────────────────────────────────────────────────────────────────────
# CloudKitchen ONE — backend environment
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` (it is gitignored). Keep secrets out of git entirely.
# ─────────────────────────────────────────────────────────────────────────────

# HTTP port the API listens on (local dev + VPS).
PORT=5003

# Auth — a long, random string used to sign/verify JWT access tokens.
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Print Agent BOOTSTRAP token (sent as the X-Agent-Token header on POST
# /agent/register ONLY — SF-2). Narrow-scope, shared install-time secret for
# the .NET tray app; never a user account / user JWT. Every OTHER agent call
# (pending pull / ack / printer heartbeat) uses the PER-AGENT token that
# /agent/register returns (raw, once) in its response — NOT this value.
AGENT_TOKEN=replace-with-a-random-agent-token

# Database — Postgres connection string (Supabase pooled URL in prod, or any Postgres).
# The automated test suite uses embedded PGlite and does NOT need this.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# CORS (SF-3) — comma-separated allowlist of exact origins allowed to call the
# API / open a Socket.IO connection. Leave unset to use the built-in defaults:
# local Vite dev origins + the known production Vercel frontend + ANY
# https://*.vercel.app origin (Vercel preview deploys). Only set this if you
# need to add something the defaults don't cover (e.g. a custom domain).
# A bare "*" is intentionally NOT supported — see src/cors.ts.
#   CORS_ORIGINS=https://your-custom-domain.com,https://staging.example.com
# CORS_ORIGIN (singular, legacy) is still read as a one-item fallback if
# CORS_ORIGINS is unset, for backward compatibility with existing deploys.
CORS_ORIGINS=

# Login rate limit (SF-3) — throttles POST /auth/login per IP. Defaults: 10
# attempts per 15 minutes in dev/prod; a very high ceiling under
# NODE_ENV=test so the test suite's own repeated login calls never trip it.
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# Cloudinary — image / photo uploads (EMS attendance photo proof, brand logos).
# REQUIRED for POST /api/v1/ems/attendance; other endpoints work without it.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
